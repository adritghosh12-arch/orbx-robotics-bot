# Copy this file to .env.local and fill in your own values

# Database Connection String
# Local: postgresql://user:password@localhost:5432/orbx_ai_local
# Render: postgresql://user:password@render-hostname:5432/orbx_ai
DATABASE_URL=postgresql://user:password@localhost:5432/orbx_ai_local

# JWT Secret Key (use a random string)
JWT_SECRET=change-me-to-a-random-secret-key-in-production

# Groq API Configuration
# Get your free key from: https://console.groq.com/docs/quickstart
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=mixtral-8x7b-32768

# Application Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development

# Optional: For local Ollama deployment (instead of Groq)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2
